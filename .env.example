# ── Open Fabric Studio — Environment Variables ────────────────────────────────
# This file is filled in automatically by install.sh.
# You can also set values manually if preferred.
#
# Generate a secret manually with: openssl rand -hex 32

# PostgreSQL password (used internally between containers — never exposed externally)
POSTGRES_PASSWORD=

# Secret for signing JWT access tokens (256-bit / 64 hex chars)
JWT_SECRET=

# Key for AES-256-GCM encryption of stored device credentials (256-bit / 64 hex chars)
# WARNING: Do not change this after installation — it will break access to saved credentials.
CREDENTIAL_ENCRYPTION_KEY=

# Host port to expose the Open Fabric Studio web UI on (default: 80)
APP_PORT=80

# Allowed CORS origins — set to your server's hostname or IP if not running on localhost
CORS_ORIGINS=http://localhost
